{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:tray:default",
    "core:window:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": ["$APPDATA/Secure2FA", "$APPDATA/Secure2FA/*"]
    }
  ]
}
