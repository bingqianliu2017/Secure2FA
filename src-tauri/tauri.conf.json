{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Secure2FA",
  "version": "0.1.0",
  "identifier": "com.secure2fa.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Secure2FA",
        "visible": false,
        "width": 380,
        "height": 520,
        "minWidth": 340,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installerHooks": "./nsis/hooks.nsh"
      },
      "wix": {
        "fragmentPaths": ["./wix/appdata-cleanup.wxs"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
